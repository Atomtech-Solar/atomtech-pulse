# HTTP + WebSocket (OCPP e realtime no mesmo processo)
PORT=8080
# Obrigatório em VPS/produção: 0.0.0.0 para aceitar conexões externas e atrás de proxy
HOST=0.0.0.0

SUPABASE_URL=
# Preferencial no backend OCPP (bypass RLS)
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# URL OCPP exibida / padrão (getOcppEndpoint no backend)
# WSS = domínio público (TLS no proxy/Railway); WS = IP direto do VPS
OCPP_DEFAULT_WSS_HOST=renewed-exploration-production.up.railway.app
OCPP_DEFAULT_WS_HOST=104.236.220.195
OCPP_DEFAULT_WS_PORT=8080
# Inatividade: sem mensagem/pong (s) → offline; sweep no banco e encerramento de socket
OCPP_IDLE_STATION_SECONDS=60
OCPP_CONNECTION_STALE_MS=60000
OCPP_STALE_SWEEP_INTERVAL_MS=30000
